# Copy to .env and adjust. Never commit .env with production secrets.

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_this_generate_a_random_secret

# HS256 JWT signing (min 32 characters recommended)
JWT_PASSPHRASE=change_me_min_32_chars_for_jwt_signing

# PostgreSQL — créer la base avant le premier lancement (README / docker compose).
DATABASE_URL="postgresql://greenit:greenit@127.0.0.1:5432/greenit?serverVersion=16&charset=utf8"

DEFAULT_URI=http://localhost:8000

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'

# Assistant IA (chatbot) — API compatible OpenAI Chat Completions (POST + Bearer)
# Ne commitez jamais la vraie clé : mettez-la dans backend/.env.local
#
# Option payante : OpenAI — https://platform.openai.com/api-keys
#
# Option gratuite (quota/limites, sujet a changement) — Groq :
#   1) Compte sur https://console.groq.com
#   2) API Keys → Create → copier la cle
#   3) Exemple ci-dessous (decommenter / adapter) :
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions
# AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# 1 = verifier TLS (defaut). 0 = desactiver verify_peer en dev si PHP/XAMPP a un CA bundle casse (jamais en prod).
AI_HTTP_VERIFY_SSL=1
# Chemin absolu vers cacert.pem (mieux que desactiver la verification)
AI_CACERT=
